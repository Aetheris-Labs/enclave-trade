{
  "name": "aegis",
  "version": "1.0.0",
  "description": "Autonomous Solana trading agent with in-enclave key custody and attested execution",
  "main": "dist/main.js",
  "type": "module",
  "bin": {
    "aegis": "./dist/main.js"
  },
  "scripts": {
    "start": "node dist/main.js",
    "dev": "bun run --watch src/main.ts",
    "build": "tsup",
    "setup": "bun run scripts/setup.ts",
    "verify": "bun run scripts/verify-attestation.ts",
    "tui": "bun run src/tui.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.54.0",
    "@noble/ed25519": "^3.1.0",
    "@solana/web3.js": "^1.98.0",
    "chromadb": "^1.9.0",
    "zod": "^3.23.0",
    "chalk": "^5.3.0",
    "ora": "^8.1.0",
    "@clack/prompts": "^0.9.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0",
    "@vitest/coverage-v8": "^2.1.0",
    "bun-types": "latest"
  },
  "keywords": [
    "solana",
    "ai-agent",
    "trading",
    "tee",
    "mcp",
    "claude",
    "defi",
    "autonomous"
  ],
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/aegis"
  }
}

